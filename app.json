{
  "expo": {
    "name": "Athlete Tracker",
    "slug": "athlete-tracker-mobile",
    "scheme": "athletetracker",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.athletetracker.mobile"
    },
    "android": {
      "package": "com.athletetracker.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#F7F4EE"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "eas": {
        "projectId": "00000000-0000-0000-0000-000000000000"
      }
    }
  }
}
